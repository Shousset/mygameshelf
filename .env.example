# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# For local dev, point this at your local Postgres. In production, use the
# connection details from your Supabase project (Settings → Database).
#
# ROW-LEVEL SECURITY (multi-tenant isolation): in production each PROCESS should
# connect as its own least-privilege role (see db/migrations/004_roles.sql):
#   - API  process: DB_USER=app_web    (NOBYPASSRLS — RLS policies enforced)
#   - worker process: DB_USER=app_worker (BYPASSRLS — operates across all users)
# Apply db/migrations/004_roles.sql and 004_rls.sql once (as a superuser) to set
# this up. In local dev you can keep DB_USER=postgres; RLS is then dormant.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mygameshelf
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection pool sizing (optional — sane defaults below). The backend keeps a
# pool of reusable connections instead of opening a new one per request.
# DB_POOL_MAX is the hard cap on concurrent connections to Postgres; keep it
# below your provider's connection limit (Supabase free tier ≈ 60).
DB_POOL_MIN=1
DB_POOL_MAX=10
# Managed Postgres (Supabase, RDS, …) requires SSL. Set to "require" in prod;
# leave unset for local dev.
# DB_SSLMODE=require

# ─── Supabase Auth ───────────────────────────────────────────────────────────
# Used by the backend to verify the JWT on every request.
# Find it in your Supabase project: Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Local dev default is the Next.js dev server. In production set this to your
# deployed frontend URL, e.g. https://mygameshelf.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Base URL of the frontend. Used as the OpenID realm / return_to for "Sign in
# through Steam". Defaults to the first ALLOWED_ORIGINS entry if unset.
FRONTEND_URL=http://localhost:3000

# ─── Steam Web API ───────────────────────────────────────────────────────────
# ONE server-side Steam Web API key for the whole app (yours, as the developer).
# Each user supplies only their own SteamID (saved per-user in the database),
# so users never need their own API key.
# Get a key (free) at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# ─── Sync worker ─────────────────────────────────────────────────────────────
# The Steam sync runs in a separate worker process (worker.py) that drains a
# Postgres-backed job queue. Both values are optional.
# WORKER_POLL_SECONDS  — how often the worker polls when the queue is empty.
# WORKER_STALE_MINUTES — requeue a job stuck "running" this long (crashed worker).
WORKER_POLL_SECONDS=5
WORKER_STALE_MINUTES=30

# ─── Steam API throttle / budget ─────────────────────────────────────────────
# All Steam calls go through a throttle with retry/backoff and a shared daily
# budget. User-independent metadata (achievement schema, global rarity, genre,
# year) is cached by appid and reused across users, so popular games cost one
# set of calls, not one per user. All optional.
# STEAM_MIN_INTERVAL_MS — min milliseconds between Steam calls (per worker).
# STEAM_MAX_RETRIES     — retries on 429/5xx before giving up.
# STEAM_DAILY_BUDGET    — max Steam calls/day across all workers (0 = unlimited).
#                         The key is capped ~100k/day; leave headroom.
STEAM_MIN_INTERVAL_MS=300
STEAM_MAX_RETRIES=4
STEAM_DAILY_BUDGET=0
# Cache TTLs in seconds (optional; sane defaults baked in):
# STEAM_SCHEMA_TTL_SECONDS=2592000     # 30 days
# STEAM_GLOBAL_TTL_SECONDS=604800      # 7 days
# STEAM_APPDETAILS_TTL_SECONDS=7776000 # 90 days
