# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mygameshelf
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Steam Web API ───────────────────────────────────────────────────────────
# Used for auto-sync (playtime, achievements, last-played, rarity).
# Without these, the app still runs; auto-sync features simply stay disabled.
#
# How to get them:
#   1. STEAM_API_KEY  →  https://steamcommunity.com/dev/apikey  (free, requires Steam account)
#   2. STEAM_ID        →  your 17-digit SteamID64 from https://store.steampowered.com/account
#                         (your profile must be set to Public for sync to work)
STEAM_API_KEY=
STEAM_ID=
